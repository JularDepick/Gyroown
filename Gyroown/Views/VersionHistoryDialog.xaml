<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Gyroown.Views.VersionHistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Style="{StaticResource DefaultContentDialogStyle}"
    PrimaryButtonText=""
    SecondaryButtonText=""
    CloseButtonText=""
    DefaultButton="Close"
    Loaded="OnLoaded"
    PrimaryButtonClick="OnRestoreClick"
    SecondaryButtonClick="OnCleanClick">

    <Grid MinWidth="500" MinHeight="350" RowDefinitions="Auto,*,Auto">
        <!-- File info -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock x:Name="FileNameText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="VersionCountText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Version list -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="Collapsed">
                <FontIcon Glyph="&#xE777;"
                          FontSize="32"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock x:Name="NoVersionsText"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Version list -->
            <ListView x:Name="VersionList"
                      SelectionMode="Single"
                      SelectionChanged="OnSelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                              Padding="0,8">
                            <!-- Version number icon -->
                            <Border Width="40" Height="40"
                                    Margin="0,0,12,0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="20">
                                <TextBlock Text="{Binding VersionNumber}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="16" />
                            </Border>

                            <!-- Version info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                                <TextBlock Text="{Binding Description}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300"
                                           ToolTipService.ToolTip="{Binding Description}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding FormattedSize}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding ContentType}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Timestamp -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FormattedTimestamp}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />

                            <!-- View button -->
                            <Button Grid.Column="3"
                                    Content="{Binding ViewButtonText}"
                                    Click="OnPreviewClick"
                                    Tag="{Binding VersionNumber}"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Preview Version" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Status bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                    Margin="0,12,0,0">
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</ContentDialog>
