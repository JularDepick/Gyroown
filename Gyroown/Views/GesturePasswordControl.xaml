<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gyroown.Views.GesturePasswordControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="HintText" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
        <Grid x:Name="GestureGrid" MaxWidth="260" MaxHeight="260" MinWidth="200" MinHeight="200"
              Background="Transparent" HorizontalAlignment="Center"
              PointerPressed="OnPress" PointerMoved="OnMove" PointerReleased="OnRelease">
            <Ellipse x:Name="E0" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18,18,0,0"/>
            <Ellipse x:Name="E1" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,18,0,0"/>
            <Ellipse x:Name="E2" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,18,18,0"/>
            <Ellipse x:Name="E3" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Left" VerticalAlignment="Center" Margin="18,0,0,0"/>
            <Ellipse x:Name="E4" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Ellipse x:Name="E5" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0"/>
            <Ellipse x:Name="E6" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="18,0,0,18"/>
            <Ellipse x:Name="E7" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18"/>
            <Ellipse x:Name="E8" Width="48" Height="48" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="2"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,18,18"/>
            <Canvas x:Name="LineCanvas" Background="Transparent"/>
        </Grid>
        <TextBlock x:Name="CountText" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
        <Button x:Name="ResetBtn" HorizontalAlignment="Center" Click="OnReset" />
    </StackPanel>
</UserControl>
