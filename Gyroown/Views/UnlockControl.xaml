<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gyroown.Views.UnlockControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*,Auto" Padding="32,48,32,24" KeyDown="OnKeyDown">
        <TextBlock Grid.Row="0" x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,16" />
        <ContentControl Grid.Row="1" x:Name="CtrlHost" />
        <StackPanel Grid.Row="2" Spacing="8" HorizontalAlignment="Center">
            <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemErrorTextColor}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Visibility="Collapsed" />
            <TextBlock x:Name="LockText" Foreground="{ThemeResource SystemErrorTextColor}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</UserControl>
