<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gyroown.Controls.TitleBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="36">

    <Grid x:Name="DragRegion" ColumnDefinitions="Auto,*" Background="Transparent" Padding="12,0">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <FontIcon Glyph="&#xE8E3;" FontSize="16" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Gyroown" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
        <TextBox x:Name="SearchBoxInput" Grid.Column="1" PlaceholderText="" MaxWidth="320"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</UserControl>
