<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gyroown.Controls.TitleBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="DragRegion" RowDefinitions="Auto" Background="Transparent" Padding="12,0">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8E3;" FontSize="16" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Gyroown" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
            <AutoSuggestBox x:Name="SearchBoxInput" Grid.Column="1" PlaceholderText="" MaxWidth="320"
                     HorizontalAlignment="Right" VerticalAlignment="Center"
                     QueryIcon="Find" UpdateTextOnSelect="False"
                     GotFocus="OnSearchGotFocus" LostFocus="OnSearchLostFocus"
                     SuggestionChosen="OnSuggestionChosen"
                     AutomationProperties.Name="Search" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
            <Button x:Name="RefreshBtn" Width="32" Height="28"
                    Click="OnRefreshClick"
                    AutomationProperties.Name="Refresh">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <Button x:Name="CheckBtn" Width="32" Height="28"
                    Click="OnCheckClick"
                    AutomationProperties.Name="Integrity Check">
                <FontIcon Glyph="&#xE73E;" FontSize="14" />
            </Button>
            <Button x:Name="AdvancedSearchBtn" Width="32" Height="28"
                    AutomationProperties.Name="Advanced Search">
                <FontIcon Glyph="&#xE71C;" FontSize="14" />
                <Button.Flyout>
                    <Flyout x:Name="AdvancedSearchFlyout" Placement="BottomEdgeAlignedRight"
                            Closing="OnFlyoutClosing">
                        <StackPanel Width="260" Spacing="12">
                            <TextBlock x:Name="FilterTitle" FontWeight="SemiBold" />

                            <!-- File type -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="FileTypeLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="CategoryCombo" HorizontalAlignment="Stretch"
                                          SelectionChanged="OnFilterChanged" />
                            </StackPanel>

                            <!-- File size -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="FileSizeLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="SizeCombo" HorizontalAlignment="Stretch"
                                          SelectionChanged="OnFilterChanged" />
                            </StackPanel>

                            <!-- Modified date -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="ModifiedDateLabel" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="DateCombo" HorizontalAlignment="Stretch"
                                          SelectionChanged="OnFilterChanged" />
                            </StackPanel>

                            <!-- Reset button -->
                            <Button x:Name="ResetFiltersBtn" HorizontalAlignment="Stretch"
                                    Click="OnResetFilters" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button x:Name="SettingsBtn" Width="32" Height="28" Click="OnSettingsClick"
                    AutomationProperties.Name="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="14" />
            </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
