<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Gyroown.Controls.Preview.ImagePreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="*,Auto">
        <!-- Image container with zoom/pan -->
        <ScrollViewer Grid.Row="0" x:Name="ImageScroller"
                      ZoomMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                      PointerWheelChanged="OnPointerWheelChanged"
                      PointerPressed="OnPointerPressed"
                      PointerMoved="OnPointerMoved"
                      PointerReleased="OnPointerReleased"
                      DoubleTapped="OnDoubleTapped"
                      MinZoomFactor="0.1" MaxZoomFactor="20"
                      Background="Transparent">
            <Image x:Name="PreviewImage" Stretch="Uniform"
                   MaxWidth="8000" MaxHeight="8000"
                   RenderTransformOrigin="0.5,0.5" />
        </ScrollViewer>

        <!-- Zoom indicator overlay -->
        <Border Grid.Row="0"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,56" Padding="12,6"
                   Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4"
                   Opacity="0.95">
            <TextBlock x:Name="ZoomIndicator"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       FontSize="13" FontWeight="SemiBold"
                       Visibility="Collapsed" />
        </Border>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Padding="8,4"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Button x:Name="ZoomOutBtn" Click="OnZoomOut" Width="32" Height="28"
                        AutomationProperties.Name="Zoom Out">
                    <FontIcon Glyph="&#xE738;" FontSize="14" />
                </Button>
                <TextBlock x:Name="ZoomPercent" Text="100%" VerticalAlignment="Center"
                           MinWidth="48" TextAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button x:Name="ZoomInBtn" Click="OnZoomIn" Width="32" Height="28"
                        AutomationProperties.Name="Zoom In">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                </Button>
                <AppBarSeparator />
                <ToggleButton x:Name="FitToggle" Checked="OnFitToggled" Unchecked="OnFitToggled"
                              IsChecked="True" Width="32" Height="28"
                              AutomationProperties.Name="Fit to Window">
                    <FontIcon Glyph="&#xE9A6;" FontSize="14" />
                </ToggleButton>
                <Button x:Name="ResetZoomBtn" Click="OnResetZoom" Width="32" Height="28"
                        AutomationProperties.Name="Reset Zoom">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
                <AppBarSeparator />
                <ToggleButton x:Name="SlideshowBtn" Checked="OnSlideshowToggled" Unchecked="OnSlideshowToggled"
                              Width="32" Height="28"
                              AutomationProperties.Name="Slideshow">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                </ToggleButton>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
